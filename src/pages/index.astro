---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import Navbar from "../components/landing/Navbar";
import Hero from "../components/landing/Hero";
import LogoTicker from "../components/landing/LogoTicker";
import Benefits from "../components/landing/Benefits";
// import PreBuiltERP from "../components/landing/PreBuiltERP";
import CaseStudiesCards from "../components/landing/CaseStudiesCards";
// import Experience from "../components/landing/Experience";
// import Solutions from "../components/landing/Solutions";
import VideoShowcase from "../components/landing/VideoShowcase";
import Pricing from "../components/landing/Pricing";
import FAQ from "../components/landing/FAQ";
import Contact from "../components/landing/Contact";
import StickyCTA from "../components/landing/StickyCTA";
import Footer from "../components/landing/Footer";
import HeroTestimonial from '../components/landing/HeroTestimonial';
import { SITE } from "../config/site.mjs";

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Puro Software",
  url: SITE.url,
  logo: new URL("/purosoftware-logo.png", SITE.url).href,
  description: "Software a medida para líderes. Automatización inteligente y desarrollo a medida para empresas que quieren escalar sin caos operativo.",
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "sales",
    url: `${SITE.url}/#contacto`,
    availableLanguage: "es",
  },
  sameAs: [
    "https://www.linkedin.com/company/puro-software",
  ],
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Puro Software",
  url: SITE.url,
  description: "Software a medida para líderes. Automatización inteligente y desarrollo a medida para empresas que quieren escalar sin caos operativo.",
  inLanguage: "es",
  publisher: {
    "@type": "Organization",
    name: "Puro Software",
    logo: new URL("/purosoftware-logo.png", SITE.url).href,
  },
};
---

<Layout
  title="Puro Software - Desarrollo de Software a Medida"
  description="Software a medida para líderes. Automatización inteligente y desarrollo a medida para empresas que quieren escalar sin caos operativo."
  canonicalURL={SITE.url}
  keywords="software a medida, desarrollo de software, automatización de procesos, software para empresas, desarrollo web, aplicaciones a medida, software para PyMEs"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(organizationSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(websiteSchema)} />

  <Navbar client:load />
  <main>
    <Hero client:load />
    {/* <PreBuiltERP client:visible /> */}
    <VideoShowcase
      client:visible
      youtubeId="MRjUQdJKYFc"
      eyebrow="El producto"
      title="Mirá la plataforma funcionando"
      description="Tour por los módulos principales de la base ERP — clientes, pedidos, stock, facturación, dashboards. Es el sistema real que adaptamos a tu operación, no una maqueta."
      align="left"
      bg="navy"
      id="demo-plataforma"
    />
    <LogoTicker client:load />
    {/* Testimoniales reales (RAZ + DentalCenter, autorizados).
        Refuerza trust antes del primer scroll. */}
    <HeroTestimonial client:load />
    <CaseStudiesCards client:visible />
    {/* <Experience client:visible /> */}
    {/* <Solutions client:visible /> */}
    <VideoShowcase
      client:visible
      youtubeId="DkeLTPPICg0"
      eyebrow="IA en acción"
      title="Inteligencia artificial en tu sistema de gestión"
      description="Tu propio asistente de IA conectado con la plataforma: puede consultar datos en tiempo real, hacer operaciones automáticas, cargar registros y entender mensajes, audios, imágenes, PDFs o lo que necesites."
      align="right"
      bg="black"
      id="demo-ia"
    />
    <Pricing client:visible />
    <Benefits client:visible />
    <FAQ client:visible />
    <Contact client:visible />
    <Footer />
  </main>
  <StickyCTA client:idle />
</Layout>
