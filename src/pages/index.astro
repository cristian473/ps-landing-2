---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import Navbar from "../components/landing/Navbar";
import Hero from "../components/landing/Hero";
import ClientLogos from "../components/landing/ClientLogos";
import Services from "../components/landing/Services";
import Portfolio from "../components/landing/Portfolio";
import HeroTestimonial from "../components/landing/HeroTestimonial";
import ErpCTABanner from "../components/landing/ErpCTABanner";
import Pricing from "../components/landing/Pricing";
import FAQ from "../components/landing/FAQ";
import Contact from "../components/landing/Contact";
import StickyCTA from "../components/landing/StickyCTA";
import Footer from "../components/landing/Footer";
import { SITE } from "../config/site.mjs";

const HOME_DESCRIPTION =
  "Software factory para negocios y empresas. Construimos web apps a medida, automatizaciones con IA, integraciones y apps móviles. Cotización por proyecto o pack mensual de horas de desarrollo.";

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Puro Software",
  url: SITE.url,
  logo: new URL("/purosoftware-logo.png", SITE.url).href,
  description: HOME_DESCRIPTION,
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "sales",
    url: `${SITE.url}/#contacto`,
    availableLanguage: ["es", "en"],
  },
  sameAs: [
    "https://www.linkedin.com/company/puro-software",
  ],
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Puro Software",
  url: SITE.url,
  description: HOME_DESCRIPTION,
  inLanguage: "es",
  publisher: {
    "@type": "Organization",
    name: "Puro Software",
    logo: new URL("/purosoftware-logo.png", SITE.url).href,
  },
};
---

<Layout
  title="Puro Software — Software factory para negocios"
  description={HOME_DESCRIPTION}
  canonicalURL={SITE.url}
  keywords="software factory, desarrollo de software a medida, web apps, automatización con IA, integraciones, apps móviles, software para negocios, software para PyMEs, agencia de desarrollo Argentina"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(organizationSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(websiteSchema)} />

  <Navbar client:load />
  <main>
    <Hero client:load />
    <ClientLogos client:load />
    <Portfolio client:visible />
    <Services client:visible />

    {/* Testimoniales reales (RAZ + DentalCenter, autorizados).
        Envuelto en <section id="testimonios"> para que el auto-tracker
        de Analytics.astro lo registre como section_view. */}
    <section id="testimonios" class="bg-black py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="text-primary font-bold tracking-wider uppercase text-xs mb-2 block">
          Lo que dicen los clientes
        </span>
        <HeroTestimonial client:visible />
      </div>
    </section>

    <ErpCTABanner client:visible />
    <Pricing client:visible />
    <FAQ client:visible />
    <Contact client:visible />
    <Footer />
  </main>
  <StickyCTA client:idle />
</Layout>
