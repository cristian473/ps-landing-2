---
export const prerender = true;

import Layout from "../../layouts/Layout.astro";
import InmobiliariaCase from "../../components/case-studies/InmobiliariaCase";
import { SITE } from "../../config/site.mjs";

const caseStudyName = "inmobiliaria";
const title = "Caso Inmobiliaria: 400 propiedades sin duplicados | Puro Software";
const description = "De WhatsApp y fichas en papel a un sistema que gestiona 400 propiedades, visitas y contratos sin que nada se pierda. Caso de éxito de desarrollo a medida.";
const canonicalURL = new URL("/casos/inmobiliaria", SITE.url).href;

const caseStudySchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  inLanguage: "es",
  author: { "@type": "Organization", name: "Puro Software", url: SITE.url },
  publisher: {
    "@type": "Organization",
    name: "Puro Software",
    logo: { "@type": "ImageObject", url: new URL("/purosoftware-logo.png", SITE.url).href },
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonicalURL },
  about: ["Software inmobiliario", "Gestión de propiedades", "CRM inmobiliario"],
};
---

<Layout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  keywords="software inmobiliario, gestión de propiedades, CRM inmobiliario, sistema inmobiliaria"
  lang="es"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(caseStudySchema)} />
  <main>
    <InmobiliariaCase client:load />
  </main>
</Layout>

<script define:vars={{ caseStudyName }}>
  // Track case study view
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof window.trackCaseStudyView === 'function') {
      window.trackCaseStudyView(caseStudyName);
    }
  });
</script>
