---
export const prerender = true;

import Layout from "../../layouts/Layout.astro";
import AcademiaCase from "../../components/case-studies/AcademiaCase";
import { SITE } from "../../config/site.mjs";

const caseStudyName = "academia";
const title = "Caso Academia de Capacitación: 1.200 alumnos gestionados | Puro Software";
const description = "De inscripciones por Google Forms y cuotas en efectivo a un sistema que gestiona 1.200 alumnos, pagos y cursadas. Caso de éxito de desarrollo a medida.";
const canonicalURL = new URL("/casos/academia", SITE.url).href;

const caseStudySchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  inLanguage: "es",
  author: { "@type": "Organization", name: "Puro Software", url: SITE.url },
  publisher: {
    "@type": "Organization",
    name: "Puro Software",
    logo: { "@type": "ImageObject", url: new URL("/purosoftware-logo.png", SITE.url).href },
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonicalURL },
  about: ["Software para academias", "Gestión de alumnos", "Sistema de capacitación"],
};
---

<Layout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  keywords="software academia capacitación, gestión alumnos, sistema inscripciones cursos, plataforma educativa"
  lang="es"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(caseStudySchema)} />
  <main>
    <AcademiaCase client:load />
  </main>
</Layout>

<script define:vars={{ caseStudyName }}>
  // Track case study view
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof window.trackCaseStudyView === 'function') {
      window.trackCaseStudyView(caseStudyName);
    }
  });
</script>
