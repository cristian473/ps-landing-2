---
export const prerender = true;

import Layout from "../../layouts/Layout.astro";
import CorralonCase from "../../components/case-studies/CorralonCase";
import { SITE } from "../../config/site.mjs";

const caseStudyName = "corralon";
const title = "Herramienta para Corralones: Presupuestos automáticos por WhatsApp | Puro Software";
const description = "Tu corralón responde presupuestos por WhatsApp al instante, aunque estés en el mostrador. Sin chatbots molestos. Sin reemplazar tu atención.";
const canonicalURL = new URL("/casos/corralon", SITE.url).href;

const caseStudySchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  inLanguage: "es",
  author: { "@type": "Organization", name: "Puro Software", url: SITE.url },
  publisher: {
    "@type": "Organization",
    name: "Puro Software",
    logo: { "@type": "ImageObject", url: new URL("/purosoftware-logo.png", SITE.url).href },
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonicalURL },
  about: ["Software para corralones", "Presupuestos automáticos WhatsApp", "Herramienta materiales de construcción"],
};
---

<Layout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  keywords="software corralón, presupuestos automáticos WhatsApp, herramienta corralón, sistema materiales construcción"
  lang="es"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(caseStudySchema)} />
  <main>
    <CorralonCase client:load />
  </main>
</Layout>

<script define:vars={{ caseStudyName }}>
  // Track case study view
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof window.trackCaseStudyView === 'function') {
      window.trackCaseStudyView(caseStudyName);
    }
  });
</script>
