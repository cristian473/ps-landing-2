---
export const prerender = true;

import Layout from "../../layouts/Layout.astro";
import DistribuidoraB2BCase from "../../components/case-studies/DistribuidoraB2BCase";
import { SITE } from "../../config/site.mjs";

const caseStudyName = "distribuidora-b2b";
const title = "Caso Distribuidora B2B: 300 pedidos/semana sin intervención manual | Puro Software";
const description = "De pedidos por WhatsApp y Excel a un portal propio que procesa 300 órdenes por semana sin intervención manual. Caso de éxito de desarrollo a medida.";
const canonicalURL = new URL("/casos/distribuidora-b2b", SITE.url).href;

const caseStudySchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  inLanguage: "es",
  author: { "@type": "Organization", name: "Puro Software", url: SITE.url },
  publisher: {
    "@type": "Organization",
    name: "Puro Software",
    logo: { "@type": "ImageObject", url: new URL("/purosoftware-logo.png", SITE.url).href },
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonicalURL },
  about: ["Portal B2B distribuidora", "Automatización de pedidos", "Software para distribuidoras"],
};
---

<Layout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  keywords="software distribuidora B2B, portal pedidos mayorista, automatización pedidos distribuidora, e-commerce B2B"
  lang="es"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(caseStudySchema)} />
  <main>
    <DistribuidoraB2BCase client:load />
  </main>
</Layout>

<script define:vars={{ caseStudyName }}>
  // Track case study view
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof window.trackCaseStudyView === 'function') {
      window.trackCaseStudyView(caseStudyName);
    }
  });
</script>
