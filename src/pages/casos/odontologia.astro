---
export const prerender = true;

import Layout from "../../layouts/Layout.astro";
import OdontologiaCase from "../../components/case-studies/OdontologiaCase";
import { SITE } from "../../config/site.mjs";

const caseStudyName = "odontologia";
const title = "Caso Clínica Odontológica: 3 sedes unificadas | Puro Software";
const description = "De agenda en papel y fichas clínicas dispersas a un sistema que gestiona 3 sedes, 800 pacientes y facturación a obras sociales. Caso de éxito de desarrollo a medida.";
const canonicalURL = new URL("/casos/odontologia", SITE.url).href;

const caseStudySchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  inLanguage: "es",
  author: { "@type": "Organization", name: "Puro Software", url: SITE.url },
  publisher: {
    "@type": "Organization",
    name: "Puro Software",
    logo: { "@type": "ImageObject", url: new URL("/purosoftware-logo.png", SITE.url).href },
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonicalURL },
  about: ["Software para clínicas odontológicas", "Gestión de pacientes", "Sistema de turnos dental"],
};
---

<Layout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  keywords="software clínica odontológica, gestión consultorios dentales, sistema turnos dentista, software obras sociales dental"
  lang="es"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(caseStudySchema)} />
  <main>
    <OdontologiaCase client:load />
  </main>
</Layout>

<script define:vars={{ caseStudyName }}>
  // Track case study view
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof window.trackCaseStudyView === 'function') {
      window.trackCaseStudyView(caseStudyName);
    }
  });
</script>
